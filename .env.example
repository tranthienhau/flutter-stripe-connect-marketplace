# Stripe Connect Marketplace POC - environment example
# Copy this file to .env and fill in your own test mode values.
# NEVER commit your real .env file.

# Stripe publishable key for the platform account (test mode, starts with pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Backend base URL where your Node.js server is reachable
BACKEND_BASE_URL=http://10.0.2.2:4242

# Platform fee in basis points (100 = 1.00%). Used by the backend stub.
PLATFORM_FEE_BPS=1000

# Toggle to run the app with seeded mock data only (no backend calls)
USE_MOCK_BACKEND=true
